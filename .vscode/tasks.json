{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dotnet watch (HcDentalClinic)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "watch",
        "--project",
        "${workspaceFolder}/src/HcDentalClinic/HcDentalClinic.csproj",
        "run"
      ],
      "options": {
        "env": {
          "DOTNET_USE_POLLING_FILE_WATCHER": "1"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": "$msCompile",
      "isBackground": true
    }
  ]
}
