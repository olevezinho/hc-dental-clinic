@page "/error"
@layout CustomLayout

<MudBreakpointProvider OnBreakpointChanged="OnBreakpointChanged">
    <ErrorBoundary>
        <div class="error-page">
            @if (IsMobile || IsSmallTablet)
            {
                <div class="error-text">
                    <MudText 
                        Class="pa-16 mt-20"
                        Style="@($"display: flex; left: 50%; justify-content: center; text-align: center; color: {Colors.Gray.Lighten5}; font-weight: bolder; z-index: 2; font-size: 1.8rem;")">
                        Erro 404 - Página não encontrada
                    </MudText>

                    <MudText Class="pa-8 mt-4"
                        Style="@($"display: flex; left: 50%; justify-content: center; text-align: center; color: {Colors.Gray.Lighten5}; font-weight: normal; z-index: 2; font-size: 1.3rem;")">
                        Pedimos desculpa, mas o conteúdo pelo qual procura foi movido ou não foi encontrado.
                    </MudText>
                    
                    <MudButton 
                        StartIcon="@Icons.Material.Filled.ArrowBack"
                        OnClick="GoBack"
                        Variant="Variant.Filled"
                        Class="mt-20"
                        @onmouseover="OnMouseOverColorChange"
                        @onmouseout="OnMouseOutColorChange"
                        Style="@($"display: flex; left: 50%; transform: translate(-50%, -50%); align-items: center; font-size: 1.6rem; color: {mudButtonTextColor}; background-color: white; border-radius: 16px;")">
                        Voltar
                    </MudButton>
                </div>
            }
            else
            {
                <div class="error-text">
                    <MudText Class="pa-16 mt-20"
                        Style="@($"display: flex; left: 50%;  justify-content: center; text-align: center; color: {Colors.Gray.Lighten5}; font-weight: bolder; z-index: 2; font-size: 2.8rem;")">
                        Erro 404 - Página não encontrada
                    </MudText>

                    <MudText Class="pa-16 mt-8"
                        Style="@($"display: flex; left: 50%;  justify-content: center; text-align: center; color: {Colors.Gray.Lighten5}; font-weight: normal; z-index: 2; font-size: 1.8rem;")">
                        Pedimos desculpa, mas o conteúdo pelo qual procura foi movido ou não foi encontrado.
                    </MudText>
                    
                    <MudButton 
                        StartIcon="@Icons.Material.Filled.ArrowBack"
                        OnClick="GoBack"
                        Variant="Variant.Filled"
                        Class="mt-16"
                        @onmouseover="OnMouseOverColorChange"
                        @onmouseout="OnMouseOutColorChange"
                        Style="@($"display: flex; top: 40%; left: 50%; transform: translate(-50%, -50%); display: flex; justify-content: center; align-items: center; font-size: 1.5rem; color: {mudButtonTextColor}; background-color: white; border-radius: 16px;")">
                        Voltar
                    </MudButton>
                </div>
            }
        </div>
    </ErrorBoundary>
    <CustomMap />
    <CustomFooter />
</MudBreakpointProvider>

@code 
{
    private MudBlazor.Breakpoint _currentBreakpoint;
    private bool IsMobile => _currentBreakpoint < MudBlazor.Breakpoint.Sm;
    private bool IsSmallTablet => _currentBreakpoint is MudBlazor.Breakpoint.Sm;
    private bool IsLargeTablet => _currentBreakpoint >= MudBlazor.Breakpoint.Md && _currentBreakpoint < MudBlazor.Breakpoint.Lg;

    private string mudButtonTextColor = Colors.BlueGray.Darken2;

    private void OnBreakpointChanged(MudBlazor.Breakpoint breakpoint)
    {
        _currentBreakpoint = breakpoint;
        StateHasChanged();
    }

    private void OnMouseOverColorChange(MouseEventArgs args)
    {
        mudButtonTextColor = MudBlazor.Colors.Brown.Lighten4;
    }

    private void OnMouseOutColorChange(MouseEventArgs args)
    {
        mudButtonTextColor = Colors.BlueGray.Darken2;
    }

    private void GoBack()
    {
        Navigation.NavigateTo(Navigation.BaseUri);
    }
}