@page "/privacy"
@layout CustomLayout

<MudBreakpointProvider OnBreakpointChanged="OnBreakpointChanged">
    <CustomAppBarMinimalistic />
    <div class="privacy-policy-page">
        @if (IsMobile || IsSmallTablet)
        {
            <MudPaper Class="mx-auto my-8" Height="auto" Width="85%"
                      Style="color:#7f745d; box-shadow: 1px 4px 4px rgba(0, 0, 0, 0.1); border-radius: 24px;">
                <div class="privacy-policy-text-mobile">
                    <MudGrid Class="mb-1" Justify="Justify.Center">
                        <MudItem xs="20" sm="20" md="20">
                            <MudImage Class="pa-4" Src="/images/background-shadowed.webp" Alt="HC Dental Clinic logótipo"
                                      Width="275" />
                        </MudItem>
                    </MudGrid>
                    <MudText Class="mb-18" Style="@($"color: #000000; font-size: 1rem; font-weight: bold;")">
                        Política de privacidade e proteção de dados
                    </MudText>
                    <MudText Class="mt-2 mb-10" Style="@($"color: {Colors.Gray.Darken1};")">
                        <strong>1. Responsável pelo Tratamento</strong>
                        <br />
                        A HC Dental Clinic (HMIRANDA & CSANTOS-MEDICINA DENTÁRIA, LDA), com sede em Rua Nicolau Coelho,
                        Edif. Santa Quitéria, No 521, Bloco 3, Frac D3, r/c dto, é a responsável pelo tratamento dos dados
                        pessoais recolhidos através deste formulário.
                        <br />
                        <br />
                        <strong>2. Dados Recolhidos e Finalidade</strong>
                        <br />
                        Recolhemos o seu nome, endereço de e-mail e [outros campos, ex: telefone] com a finalidade exclusiva
                        de responder à sua solicitação, pedido de orçamento ou questão.
                        <br />
                        <br />
                        <strong>3. Base Legal e Consentimento</strong>
                        <br />
                        Ao submeter o formulário, está a dar o seu consentimento para o tratamento dos dados, conforme
                        exigido pelo Regulamento Geral de Proteção de Dados (RGPD).
                        <br />
                        <br />
                        <strong>4. Partilha de Dados</strong>
                        <br />
                        Os seus dados não serão vendidos ou partilhados com terceiros, exceto no cumprimento de obrigações
                        legais.
                        <br />
                        <br />
                        <strong>5. Retenção de Dados</strong>
                        <br />
                        Os seus dados serão armazenados apenas pelo tempo necessário para responder à sua questão, sendo
                        posteriormente eliminados, a menos que se inicie uma relação contratual.
                        <br />
                        <br />
                        <strong>6. Direitos do Utilizador</strong>
                        <br />
                        Pode, a qualquer momento, solicitar o acesso, retificação, eliminação ou portabilidade dos seus
                        dados, enviando um e-mail para: mailto:geral@hcdentalclinic.pt.
                    </MudText>
                </div>
            </MudPaper>
        }
