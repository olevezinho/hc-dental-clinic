<div class="wip-container">
    <h1 class="wip-text">Estamos a preparar algo especial para si.</h1>

    <img src="/images/background-shadowed.png"
         alt="Work in progress"
         class="wip-image @(imageLoaded ? "visible" : "loading")"
     @onload="OnImageLoaded" />
</div>

@code 
{
    private bool imageLoaded;
    private void OnImageLoaded() => imageLoaded = true;
}
