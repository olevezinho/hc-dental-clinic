<section id="mission">
    <MudBreakpointProvider OnBreakpointChanged="OnBreakpointChanged">
        @if(IsMobile)
        {
            <div class="mission-container-mobile">
                <h1 class="mission-text">A nossa missão</h1>
                <MudText 
                    Typo="Typo.h5" 
                    Class="pa-12 mt-2"
                    Align="Align.Center"
                    Style="font-weight: 300; color: #807f7f; font-size: 1.1rem;">
                    Acreditamos que todos merecem um sorriso saudável e bonito. A nossa missão é<br />
                    fornecer cuidados dentários excepcionais que combinam a mais recente tecnologia<br />
                    com uma abordagem suave e compassiva, adequada para pacientes de todas as idades.
                </MudText>
                <MudGrid Class="pa-2 mt-2 mb-8" Justify="Justify.Center">
                    <MudItem xs="10" sm="6" md="3" Class="d-flex justify-center align-center">
                        <MudPaper
                            @onmouseover="OnMouseOverCompassiveCareShadowIncrease"
                            @onmouseout="OnMouseOutCompassiveCareShadowDecrease"
                            Style="@($"background-color: #ffffff; border-radius: 24px; box-shadow: {defaultCompassiveCareShadow} text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.25);")">
                            <MudGrid Class="pa-6 mt-1">
                                <MudItem xs="12" Style="display: flex; justify-content: center; align-items: center;">
                                    <div class="rounded-circle" style="background-color: #f5f2ef; margin-top: 1rem; min-width: 5.2rem; min-height: 5.2rem; max-width: 5.5rem; max-height: 5.5rem;">
                                        <MudIcon 
                                            Icon="@Icons.Material.Rounded.FavoriteBorder"
                                            Style="color: #ad9587; font-size: 4.4rem; margin-top: 0.3rem;" />
                                    </div>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.h3" Class="pa-4" Align="Align.Center"
                                        Style="@($"color: {Colors.Gray.Darken3}; font-weight: bold;")">
                                        Cuidado Compassivo
                                    </MudText>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.h6" Class="pa-4" Align="Align.Center"
                                        Style="@($"color: {Colors.Gray.Darken1}; font-weight: 250;")">
                                        Tratamos cada paciente com cuidado e compreensão, conforto e tranquilidade
                                    </MudText>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="10" sm="6" md="3" Class="d-flex justify-center align-center">
                        <MudPaper
                            @onmouseover="OnMouseOverForTheFamilyShadowIncrease"
                            @onmouseout="OnMouseOutForTheFamilyShadowDecrease"
                            Style="@($"background-color: #ffffff; border-radius: 24px; box-shadow: {defaultForTheFamilyShadow} text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.25);")">
                            <MudGrid Class="pa-6 mt-1">
                                <MudItem xs="12" Style="display: flex; justify-content: center; align-items: center;">
                                    <div class="rounded-circle" style="background-color: #dcfce7; margin-top: 1rem;min-width: 5.2rem; min-height: 5.2rem; max-width: 5.5rem; max-height: 5.5rem;">
                                        <MudIcon Icon="@Icons.Material.Filled.FamilyRestroom"
                                            Style="color: #00c951; font-size: 4.2rem; margin-top: 0.3rem;" />
                                    </div>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.h3" Class="pa-4" Align="Align.Center"
                                        Style="@($"color: {Colors.Gray.Darken3}; font-weight: bold;")">
                                        Para Toda a Família
                                    </MudText>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.h6" Class="pa-4" Align="Align.Center"
                                        Style="@($"color: {Colors.Gray.Darken1}; font-weight: 250;")">
                                        Dos mais novos aos mais velhos, criamos um ambiente acolhedor para toda a família
                                    </MudText>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="10" sm="6" md="3" Class="d-flex justify-center align-center">
                        <MudPaper 
                            @onmouseover="OnMouseOverQualityExcelenceShadowIncrease"
                            @onmouseout="OnMouseOutQualityExcelenceShadowDecrease"
