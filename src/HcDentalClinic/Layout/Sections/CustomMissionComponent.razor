                                <MudItem xs="12" Style="display: flex; justify-content: center; align-items: center;">
                                    <div class="rounded-circle" style="background-color: #f3e8ff; margin-top: 1rem; min-width: 5.2rem; min-height: 5.2rem; max-width: 5.5rem; max-height: 5.5rem;">
                                        <MudIcon Icon="@Icons.Material.Filled.MilitaryTech"
                                            Style="color: #ad46ff; font-size: 4.4rem; margin-top: 0.3rem;" />
                                    </div>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.h3" Class="pa-4" Align="Align.Center"
                                        Style="@($"color: {Colors.Gray.Darken3}; font-weight: bold;")">
                                        Excelência de Qualidade
                                    </MudText>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.h6" Class="pa-4" Align="Align.Center"
                                        Style="@($"color: {Colors.Gray.Darken1}; font-weight: 250;")">
                                        Utilizamos tecnologia de ponta e técnicas comprovadas para os melhores resultados
                                    </MudText>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </div>
        }
