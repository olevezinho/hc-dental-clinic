                <MudGrid Class="pa-10 mt-10" Justify="Justify.Center" Spacing="6">
                    <MudItem xs="8" sm="4" md="3" Class="d-flex justify-center align-center" Style="min-height: 22rem;">
                        <MudPaper
                            @onmouseover="OnMouseOverCompassiveCareShadowIncrease"
