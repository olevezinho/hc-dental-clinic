@code 
{
    private MudBlazor.Breakpoint _currentBreakpoint;
    private bool IsMobile => _currentBreakpoint < MudBlazor.Breakpoint.Sm;
    private bool IsSmallTablet => _currentBreakpoint is MudBlazor.Breakpoint.Sm;
    private bool IsLargeTablet => _currentBreakpoint >= MudBlazor.Breakpoint.Md && _currentBreakpoint < MudBlazor.Breakpoint.Lg;

    private string defaultCompassiveCareShadow = "0px 0px 6px rgba(20, 20, 20, 0.1);";
    private string defaultForTheFamilyShadow = "0px 0px 6px rgba(20, 20, 20, 0.1);";
    private string defaultQualityExcelenceShadow = "0px 0px 6px rgba(20, 20, 20, 0.1);";

    private void OnBreakpointChanged(MudBlazor.Breakpoint breakpoint)
    {
        _currentBreakpoint = breakpoint;
        StateHasChanged();
    }

    private void OnMouseOverCompassiveCareShadowIncrease(MouseEventArgs args)
    {
        defaultCompassiveCareShadow = "0px 4px 12px rgba(20, 20, 20, 0.25);";
    }
    private void OnMouseOutCompassiveCareShadowDecrease(MouseEventArgs args)
    {
        defaultCompassiveCareShadow = "0px 0px 6px rgba(20, 20, 20, 0.1);";
    }
    private void OnMouseOverForTheFamilyShadowIncrease(MouseEventArgs args)
    {
        defaultForTheFamilyShadow = "0px 4px 12px rgba(20, 20, 20, 0.25);";
    }
    private void OnMouseOutForTheFamilyShadowDecrease(MouseEventArgs args)
    {
        defaultForTheFamilyShadow = "0px 0px 6px rgba(20, 20, 20, 0.1);";
    }
    private void OnMouseOverQualityExcelenceShadowIncrease(MouseEventArgs args)
    {
        defaultQualityExcelenceShadow = "0px 4px 12px rgba(20, 20, 20, 0.25);";
    }
    private void OnMouseOutQualityExcelenceShadowDecrease(MouseEventArgs args)
    {
        defaultQualityExcelenceShadow = "0px 0px 6px rgba(20, 20, 20, 0.1);";
    }
}