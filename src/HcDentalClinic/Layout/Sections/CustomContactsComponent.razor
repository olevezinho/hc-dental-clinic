@code 
{
    private MudBlazor.Breakpoint _currentBreakpoint;
    private bool IsMobile => _currentBreakpoint < MudBlazor.Breakpoint.Sm;
    private bool IsSmallTablet => _currentBreakpoint is MudBlazor.Breakpoint.Sm;
    private bool IsLargeTablet => _currentBreakpoint >= MudBlazor.Breakpoint.Md && _currentBreakpoint < MudBlazor.Breakpoint.Lg;

    private string phoneShadow = "0px 0px 6px rgba(20, 20, 20, 0.1);";
    private string emailShadow = "0px 0px 6px rgba(20, 20, 20, 0.1);";
    private string addressShadow = "0px 0px 6px rgba(20, 20, 20, 0.1);";
    private string scheduleShadow = "0px 0px 6px rgba(20, 20, 20, 0.1);";

    private void OnBreakpointChanged(MudBlazor.Breakpoint breakpoint)
    {
        _currentBreakpoint = breakpoint;
        StateHasChanged();
    }

    private void OnMouseOverPhoneShadow(MouseEventArgs args) => phoneShadow = "0px 8px 16px rgba(20, 20, 20, 0.2);";
    private void OnMouseOutPhoneShadow(MouseEventArgs args) => phoneShadow = "0px 0px 6px rgba(20, 20, 20, 0.1);";

    private void OnMouseOverEmailShadow(MouseEventArgs args) => emailShadow = "0px 8px 16px rgba(20, 20, 20, 0.2);";
    private void OnMouseOutEmailShadow(MouseEventArgs args) => emailShadow = "0px 0px 6px rgba(20, 20, 20, 0.1);";

    private void OnMouseOverAddressShadow(MouseEventArgs args) => addressShadow = "0px 8px 16px rgba(20, 20, 20, 0.2);";
    private void OnMouseOutAddressShadow(MouseEventArgs args) => addressShadow = "0px 0px 6px rgba(20, 20, 20, 0.1);";

    private void OnMouseOverScheduleShadow(MouseEventArgs args) => scheduleShadow = "0px 8px 16px rgba(20, 20, 20, 0.2);";
    private void OnMouseOutScheduleShadow(MouseEventArgs args) => scheduleShadow = "0px 0px 6px rgba(20, 20, 20, 0.1);";
