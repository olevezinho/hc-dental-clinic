@code 
{
    private MudBlazor.Breakpoint _currentBreakpoint;
    private bool IsMobile => _currentBreakpoint < MudBlazor.Breakpoint.Sm;
    private bool IsSmallTablet => _currentBreakpoint is MudBlazor.Breakpoint.Sm;
    private bool IsLargeTablet => _currentBreakpoint >= MudBlazor.Breakpoint.Md && _currentBreakpoint < MudBlazor.Breakpoint.Lg;

    private int _mediaHeight = 400;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var windowHeight = await JSRuntime.InvokeAsync<int>("getWindowHeight");
            _mediaHeight = windowHeight switch
            {
                >= 700 => 400,
                >= 600 => 325,
                _      => 250
            };
            StateHasChanged();
        }
    }

    private string defaultPreviousButtonShadow = "0px 2px 4px rgba(0, 0, 0, 0.1);";
    private string defaultPreviousButtonBackground = "white";
    private string defaultNextButtonShadow = "0px 2px 4px rgba(0, 0, 0, 0.1);";
    private string defaultNextButtonBackground = "white";
    private int carouselIndex = 0;

    private List<TeamMember> team = TeamData.Members;

    private Dictionary<int, string> cardShadows = new();
    private Dictionary<int, string> cardImageStyles = new();

    private void OnBreakpointChanged(MudBlazor.Breakpoint breakpoint)
    {
        _currentBreakpoint = breakpoint;
        StateHasChanged();
    }

    protected override void OnInitialized()
    {
        // Initialize shadow and image styles for all team members
        foreach (var member in team)
        {
            cardShadows[member.Id] = "1px 1px 6px rgba(20, 20, 20, 0.1);";
            cardImageStyles[member.Id] = "object-fit: cover; object-position: center; transition: transform 0.8s ease;";
        }
    }

    private void OnMouseOverPreviousButton(MouseEventArgs args)
    {
        defaultPreviousButtonShadow = "0px 4px 8px rgba(0, 0, 0, 0.2);";
        defaultPreviousButtonBackground = "#f5f5f5";
    }

    private void OnMouseOutPreviousButton(MouseEventArgs args)
    {
        defaultPreviousButtonShadow = "0px 2px 4px rgba(0, 0, 0, 0.1);";
        defaultPreviousButtonBackground = "white";
    }

    private void OnMouseOverNextButton(MouseEventArgs args)
    {
        defaultNextButtonShadow = "0px 4px 8px rgba(0, 0, 0, 0.2);";
        defaultNextButtonBackground = "#f5f5f5";
    }

    private void OnMouseOutNextButton(MouseEventArgs args)
    {
        defaultNextButtonShadow = "0px 2px 4px rgba(0, 0, 0, 0.1);";
        defaultNextButtonBackground = "white";
    }

    // Get visible team members (creates infinite carousel by cycling through)
    private List<TeamMember> GetVisibleDesktopTeamMembers(int count = 4)
    {
        var result = new List<TeamMember>();
        for (int i = 0; i < count; i++)
        {
            int idx = (carouselIndex + i) % team.Count;
            result.Add(team[idx]);
        }
        return result;
    }

    private void Next()
    {
        carouselIndex = (carouselIndex + 1) % team.Count;
    }
    
    private void Previous()
    {
        carouselIndex = (carouselIndex - 1 + team.Count) % team.Count;
    }

    private string GetCardShadow(int memberId)
    {
        return cardShadows.ContainsKey(memberId) ? cardShadows[memberId] : "1px 1px 6px rgba(20, 20, 20, 0.1);";
    }

    private string GetCardImageStyle(int memberId)
    {
        return cardImageStyles.ContainsKey(memberId) ? cardImageStyles[memberId] : "object-fit: cover; object-position: center; transition: transform 0.8s ease;";
    }

    private void OnMouseOverCard(int memberId)
    {
        cardShadows[memberId] = "4px 4px 12px rgba(20, 20, 20, 0.25);";
        cardImageStyles[memberId] = "transform: scale(1.05); display: block; object-fit: cover;";
    }

    private void OnMouseOutCard(int memberId)
    {
        cardShadows[memberId] = "1px 1px 6px rgba(20, 20, 20, 0.1);";
        cardImageStyles[memberId] = "object-fit: cover; object-position: center; transition: transform 0.8s ease;";
    }

    private async Task OpenMemberDialogAsync(TeamMember member)
    {        
        var parameters = new DialogParameters 
        { 
            ["Member"] = member
        };

        var options = new DialogOptions 
        { 
            BackgroundClass = "dialog-styles", 
            NoHeader = true
        };
        var dialog = await Dialog.ShowAsync<TeamMemberDialog>("", parameters, options);
        await dialog.Result;
    }
}