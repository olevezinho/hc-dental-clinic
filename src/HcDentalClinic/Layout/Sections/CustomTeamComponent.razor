<section id="team">
    <MudBreakpointProvider OnBreakpointChanged="OnBreakpointChanged">
        @if(IsMobile)
        {
            <div class="team-container-mobile">
                <h1 class="team-text">Conheça a Nossa Equipa</h1>
                <MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">
                    <MudText 
                        Typo="Typo.h5" 
                        Class="pa-12 mt-2 mb-20"
                        Align="Align.Center"
                        Style="font-weight: 250; color: #807f7f; font-size: 1.3rem;">
                        Os nossos profissionais dentários experientes e simpáticos estão aqui para cuidar do seu sorriso
                    </MudText>
                    <MudCarousel 
                        Class="pa-1 mb-8"
                        ItemsSource="team"
                        ShowArrows="false"
                        ShowBullets="false"
                        EnableSwipeGesture="true"
                        ArrowsPosition="Position.Center"
                        TData="TeamMember"
                        AutoCycle="true"
                        Style="min-height: 650px;">
                        <ItemTemplate>
                            <MudGrid 
                                Justify="Justify.Center" 
                                Spacing="4"
                                Style="align-content: center; height: 100%;">
                                <MudItem xs="10" sm="6" md="3" Class="d-flex justify-center align-center">
                                    <MudPaper
                                        @onclick="@(() => OpenMemberDialogAsync(context))"
                                        @onmouseover="@(() => OnMouseOverCard(context.Id))"
                                        @onmouseout="@(() => OnMouseOutCard(context.Id))"
                                        Style="@($"background-color: #ffffff; border-radius: 24px; box-shadow: {GetCardShadow(context.Id)}; text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.25); cursor: pointer;")">
                                        <MudCard Style="border-radius: 24px; overflow: hidden;">
                                                <div class="team-media-container">
                                                <MudCardMedia 
                                                    Image="@context.ImageUrl"
                                                    Style="@($"{GetCardImageStyle(context.Id)}")"
                                                    Height="@_mediaHeight"/>
                                            </div>
                                            <MudCardContent Style="height: 240px;">
                                                <MudText Typo="Typo.body2" Style="font-size: 1.1rem;">@context.Name</MudText>
                                                <MudText Typo="Typo.body2" Class="mt-2" Style="color: #ad9587;">@context.PositionText</MudText>
                                                <MudText Typo="Typo.body2" Class="mt-2" Style="color: #807f7f;">@context.Description</MudText>
                                            </MudCardContent>
                                        </MudCard>
                                    </MudPaper>
                                </MudItem>
                            </MudGrid>
                        </ItemTemplate>
                    </MudCarousel>
                </MudContainer>
            </div>
        }
        else if(IsSmallTablet)
        {
            <div class="team-container-mobile">
                <h1 class="team-text">Conheça a Nossa Equipa</h1>
                <MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">
                    <MudText 
                        Typo="Typo.h5" 
                        Class="mt-1 mb-20"
                        Align="Align.Center"
                        Style="font-weight: 250; color: #807f7f; font-size: 1.3rem;">
                        Os nossos profissionais dentários experientes e simpáticos estão aqui para cuidar do seu sorriso
                    </MudText>
                    <div class="carousel-nav-wrapper mb-8" style="position: relative; width: 100%;">
                        <div style="position: absolute; left: -1rem; top: 50%; transform: translateY(-50%); z-index: 2;">
                            <div class="mud-button-root mud-icon-button mud-icon-button-color-inherit mud-ripple mud-ripple-icon"
                                @onmouseover="OnMouseOverPreviousButton"
                                @onmouseout="OnMouseOutPreviousButton"
                                @onclick="Previous"
                                style="border-radius: 24px; background-color: @defaultPreviousButtonBackground; box-shadow: @defaultPreviousButtonShadow; margin-left: 2rem; transition: all 0.3s ease;">
                                <span class="mud-icon-button-label">
                                    <MudIcon Class="mud-ripple mud-ripple-icon mud-icon-button-size-medium" Icon="@Icons.Material.Rounded.KeyboardArrowLeft" Color="@Color.Inherit" />
                                </span>
                            </div>
                        </div>
                        <MudGrid Justify="Justify.Center" Spacing="10" Style="align-content: center; margin-top: -1.5rem;">
                            @foreach (var member in GetVisibleDesktopTeamMembers(2))
                            {
                                <MudItem xs="8" sm="4" md="3" Class="d-flex justify-center align-center">
                                    <MudPaper
